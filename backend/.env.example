# ============================================================
#  .env.example — Copy this file to .env and fill in your values
#
#  IMPORTANT: NEVER commit .env to Git!
#  Add .env to your .gitignore file.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# Local development example:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/craftyoursystems
#
# Railway / Render / Supabase (they give you this URL directly):
# DATABASE_URL=postgresql://user:pass@db.somecloud.com:5432/railway

# ── JWT Secret Key ───────────────────────────────────────────
# This is used to sign and verify JWT tokens.
# Make it long, random, and secret — like a password.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string-minimum-32-chars

# ── CORS ─────────────────────────────────────────────────────
# In development: * allows all origins
# In production: set this to your actual domain
ALLOWED_ORIGIN=http://localhost:5500

# ── EmailJS (used on the FRONTEND, not here) ─────────────────
# These go into your HTML/JS, NOT this file.
# But document them here for reference.
# EMAILJS_SERVICE_ID=service_xxxxxxx
# EMAILJS_TEMPLATE_ID=template_xxxxxxx
# EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
