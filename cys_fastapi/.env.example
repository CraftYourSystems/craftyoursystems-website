# ============================================================
#  .env.example — Copy to .env and fill in your real values
#
#  ⚠️  NEVER commit .env to Git — add it to .gitignore
# ============================================================

# ── PostgreSQL connection ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/craftyoursystems
#
# Cloud (Railway gives you this directly):
# DATABASE_URL=postgresql://postgres:abc123@containers-us-west.railway.app:1234/railway

# ── JWT signing key ──────────────────────────────────────────
# Must be long and random. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-64-random-hex-characters-minimum

# ── Token lifetime ───────────────────────────────────────────
JWT_EXPIRE_HOURS=1

# ── CORS ─────────────────────────────────────────────────────
# Development: * allows all
# Production: your actual domain
ALLOWED_ORIGIN=http://localhost:5500

# ── EmailJS (frontend only, document here for reference) ─────
# These go in js/main.js — NOT in this file
# EMAILJS_SERVICE_ID=service_xxxxxxx
# EMAILJS_TEMPLATE_ID=template_xxxxxxx
# EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
